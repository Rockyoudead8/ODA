<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 Not Found</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-r from-purple-500 via-pink-500 to-red-500 min-h-screen flex items-center justify-center">
  <div class="bg-white rounded-3xl shadow-2xl p-12 text-center max-w-lg">
    <h1 class="text-8xl font-extrabold text-gray-800 mb-6 animate-bounce">404</h1>
    <h2 class="text-3xl font-bold text-gray-700 mb-4">Oops! Page not found</h2>
    <p class="text-gray-600 mb-8">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="inline-block px-6 py-3 bg-purple-600 text-white font-semibold rounded-lg shadow-lg hover:bg-purple-700 transition">
      Go Back Home
    </a>
  </div>
</body>
</html>
